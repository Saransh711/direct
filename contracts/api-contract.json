        "phoneNumber": "string",
        "password": "string",
        "confirmPassword": "string"
      },
      "validationRules": ["password strength", "confirmPassword matches", "unique email/phone"],
      "requestExample": {
        "firstName": "John",
        "lastName": "Doe",
        "email": "john@example.com",
        "phoneNumber": "+911234567890",
        "password": "Str0ng@Password!",
        "confirmPassword": "Str0ng@Password!"
      },
      "responseSchema": { "id": "uuid", "email": "string" },
      "responseExample": {
        "success": true,
        "message": "Customer registered successfully",
        "data": { "id": "uuid", "email": "john@example.com" }
      },
      "errorResponses": [400, 409],
      "pagination": null
